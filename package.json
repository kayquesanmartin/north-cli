{
  "name": "north-cli",
  "version": "0.12.0",
  "description": "Copiloto de produtividade multi-projeto para o Claude Code: foco do dia, sinais vitais e painel — lê seus planos (plan-build/GSD) e nunca os edita.",
  "bin": {
    "north": "bin/north.js"
  },
  "files": [
    "bin/",
    "src/",
    "skills/",
    "templates/",
    "references/",
    "install.py",
    "runtimes.py",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepack": "node bin/clean-pycache.js",
    "postinstall": "node -e \"process.stdout.write('north-cli instalado. Rode: north install\\n')\"",
    "test": "python -m unittest discover -s tests -p \"test_*.py\""
  },
  "keywords": [
    "claude-code",
    "productivity",
    "cli",
    "dashboard",
    "project-management",
    "gsd",
    "developer-tools",
    "kanban"
  ],
  "bin_note": "north é um app Python; este pacote npm é só o lançador cross-plataforma (detecta python3/python/py e roda install.py/run.py).",
  "engines": {
    "node": ">=14"
  },
  "preferGlobal": true,
  "license": "MIT",
  "author": "Kayque Sanmartin de Assis",
  "homepage": "https://github.com/kayquesanmartin/north-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kayquesanmartin/north-cli.git"
  },
  "bugs": {
    "url": "https://github.com/kayquesanmartin/north-cli/issues"
  }
}
